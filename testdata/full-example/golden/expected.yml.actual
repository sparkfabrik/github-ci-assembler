# ┌──────────────────────────────────────────────────────────────────────┐
# │ AUTO-GENERATED by gh-ci-assembler — do not edit manually             │
# │ Source: configuration.yml, pkg_base.yml, pkg_drupal.yml, pkg_redis.yml, project.yml│
# │ Generated: 2025-01-01T00:00:00Z                                       │
# └──────────────────────────────────────────────────────────────────────┘

name: GitHub CI Assembler
on:
  pull_request:
    branches:
      - main
  push:
    branches:
      - main
      - develop
defaults:
  run:
    shell: bash
env:
  CI_ORCHESTRATOR: gh-ci-assembler
  GLOBAL_TIMEOUT: "600"
permissions:
  actions: read
  checks: write
  contents: read
  id-token: write
  pull-requests: write
  statuses: write
jobs:
  #  ── Stage: build ─────────────────────────────────────
  build--base--placeholder:
    name: placeholder - base [build]
    runs-on: ubuntu-latest
    steps:
      - name: Placeholder
        run: echo "Base package placeholder"
  build--drupal--docker-nginx:
    name: docker-nginx - drupal [build]
    runs-on: ubuntu-latest
    env:
      PHP_VERSION: "8.2"
    steps:
      - uses: actions/checkout@v4
      - name: Build nginx configuration
        run: ./scripts/build-nginx.sh
  build--drupal--docker-php:
    name: Build PHP image - drupal [build]
    runs-on: ubuntu-latest
    services:
      postgres:
        image: postgres:16
        ports:
          - 5432:5432
    env:
      DATABASE_URL: postgres://db:5432/myapp
      DEPLOY_ENV: staging
      PHP_VERSION: "8.2"
      REDIS_HOST: redis
      SLACK_WEBHOOK: https://hooks.slack.com/services/...
    steps:
      - uses: actions/checkout@v4
      - name: Setup PHP
        uses: shivammathur/setup-php@v2
        with:
          php-version: "8.2"
      - name: Install dependencies
        run: composer install --no-interaction
  build--redis--docker-redis:
    name: Build Redis image - redis [build]
    runs-on: ubuntu-latest
    env:
      DEPLOY_ENV: staging
      SLACK_WEBHOOK: https://hooks.slack.com/services/...
    steps:
      - uses: actions/checkout@v4
      - name: Build custom Redis image
        run: ./scripts/build-redis.sh
  #  ── Stage: notify ────────────────────────────────────
  notify--drupal--notify:
    name: notify - drupal [notify]
    needs: [build--base--placeholder, build--drupal--docker-nginx, build--drupal--docker-php, build--redis--docker-redis]
    runs-on: ubuntu-latest
    env:
      DEPLOY_ENV: staging
      PHP_VERSION: "8.2"
      SLACK_WEBHOOK: https://hooks.slack.com/services/...
    steps:
      - name: Custom notification
        run: |
          curl -X POST $SLACK_WEBHOOK \
            -d '{"text": "Build complete for ${{ github.repository }}"}'
  notify--redis--notify:
    name: notify - redis [notify]
    needs: [build--base--placeholder, build--drupal--docker-nginx, build--drupal--docker-php, build--redis--docker-redis]
    runs-on: ubuntu-latest
    continue-on-error: true
    env:
      REDIS_VERSION: "7"
    steps:
      - name: Notify Redis build complete
        run: echo "Redis image built."
  #  ── Stage: test ──────────────────────────────────────
  #  test--redis--job-test: DISABLED by project.yml
  custom-lint:
    name: custom-lint [test]
    needs: [notify--drupal--notify, notify--redis--notify]
    runs-on: ubuntu-latest
    env:
      DEPLOY_ENV: staging
      SLACK_WEBHOOK: https://hooks.slack.com/services/...
    steps:
      - uses: actions/checkout@v4
      - name: Run project linter
        run: ./scripts/lint.sh
  test--drupal--phpunit:
    name: PHPUnit test suite - drupal [test]
    needs: [notify--drupal--notify, notify--redis--notify]
    runs-on: ubuntu-latest
    env:
      PHP_VERSION: "8.2"
    steps:
      - uses: actions/checkout@v4
      - name: Run PHPUnit
        run: vendor/bin/phpunit --coverage-text
  #  ── Stage: deploy ────────────────────────────────────
  deploy--redis--push-redis-image:
    name: push-redis-image - redis [deploy]
    needs: [custom-lint, test--drupal--phpunit]
    runs-on: ubuntu-latest
    env:
      REDIS_VERSION: "7"
    steps:
      - uses: actions/checkout@v4
      - name: Push Redis image
        uses: docker/build-push-action@v5
        with:
          context: ./docker/redis
          push: "true"
          tags: ghcr.io/myorg/myapp-redis:latest
